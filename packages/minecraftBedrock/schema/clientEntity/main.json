{
	"$schema": "http://json-schema.org/draft-07/schema",
	"title": "Client Entity",
	"type": "object",
	"required": [
		"format_version",
		"minecraft:client_entity"
	],
	"allOf": [
		{
			"properties": {
				"format_version": {
					"title": "Format Version",
					"$ref": "../project/formatVersionEnum.json"
				}
			}
		},
		{
			"if": {
				"properties": {
					"format_version": {
						"enum": [
							"1.8.0",
							"1.9.0"
						]
					}
				}
			},
			"then": {
				"$ref": "./v1.8.0/main.json"
			}
		},
		{
			"if": {
				"properties": {
					"format_version": {
						"enum": [
							"1.10.0",
							"1.26.0"
						]
					}
				}
			},
			"then": {
				"$ref": "./v1.10.0/main.json"
			}
		},
		{
			"if": {
				"properties": {
					"format_version": {
						"enum": [
							"1.26.10"
						]
					}
				}
			},
			"then": {
				"$ref": "./v1.26.10/main.json"
			},
			"else": {
				"$ref": "./v1.10.0/main.json"
			}
		}
	]
}