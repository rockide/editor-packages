{
	"$schema": "http://json-schema.org/draft-07/schema",
	"defaultSnippets": [
		{
			"label": "New client entity",
			"body": {
				"format_version": "${1:1.26.0}",
				"minecraft:client_entity": {
					"description": {
						"identifier": "$2:${3:${TM_FILENAME/[\\.].*//}}",
						"materials": {
							"default": "entity_alphatest"
						},
						"textures": {
							"default": "textures/$2/entity/${3:${TM_FILENAME/[\\.].*//}}"
						},
						"geometry": {
							"default": "geometry.$2.${3:${TM_FILENAME/[\\.].*//}}"
						},
						"render_controllers": ["controller.render.default"]
					}
				}
			}
		}
	],
	"title": "Client Entity",
	"type": "object",
	"required": ["format_version", "minecraft:client_entity"],
	"allOf": [
		{
			"properties": {
				"format_version": {
					"title": "Format Version",
					"$ref": "../project/formatVersionEnum.json"
				}
			}
		},
		{
			"if": {
				"properties": {
					"format_version": {
						"enum": ["1.8.0", "1.9.0"]
					}
				}
			},
			"then": {
				"$ref": "./v1.8.0/main.json"
			}
		},
		{
			"if": {
				"properties": {
					"format_version": {
						"enum": ["1.10.0", "1.26.0"]
					}
				}
			},
			"then": {
				"$ref": "./v1.10.0/main.json"
			},
			"else": {
				"$ref": "./v1.10.0/main.json"
			}
		}
	]
}
